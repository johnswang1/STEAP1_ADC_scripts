res_wt_iso_df$Geneid_clean <- sub("\\..*$", "", res_wt_iso_df$Geneid_clean)

res_wt_iso_df$SYMBOL <- mapIds(
  org.Mm.eg.db,
  keys      = res_wt_iso_df$Geneid_clean,
  column    = "SYMBOL",
  keytype   = "ENSEMBL",
  multiVals = "first"
)

res_wt_iso_df$label <- ifelse(
  is.na(res_wt_iso_df$SYMBOL),
  res_wt_iso_df$Geneid_clean,
  res_wt_iso_df$SYMBOL
)

res_wt_iso_df <- res_wt_iso_df[order(res_wt_iso_df$label, res_wt_iso_df$padj, na.last = TRUE), ]
res_wt_iso_df <- res_wt_iso_df[!duplicated(res_wt_iso_df$label), ]
rownames(res_wt_iso_df) <- res_wt_iso_df$label

complement_genes <- c(
  "C3", "C4b", "C4a", "C2",
  "C1qa", "C1qb", "C1qc", "C1r", "C1s",
  "C3ar1", "C5ar1", "C5ar2",
  "C6", "C7", "C8a", "C8b", "C9",
  "Cfb", "Cfd", "Cfh", "Cfi", "Cfp",
  "Masp1", "Masp2", "Mbl1", "Mbl2",
  "Serping1", "Cr2",
  "Cd55", "Cd59a",
  "Fcna", "Fcnb"
)

complement_present <- intersect(complement_genes, rownames(res_wt_iso_df))

res_wt_iso_df$log10FC        <- res_wt_iso_df$log2FoldChange / log2(10)
res_wt_iso_df$neg_log10_padj <- -log10(res_wt_iso_df$padj)

res_wt_iso_df$sig <- ifelse(
  !is.na(res_wt_iso_df$padj) & res_wt_iso_df$padj < 0.05,
  "Significant", "NS"
)
res_wt_iso_df$sig <- factor(res_wt_iso_df$sig, levels = c("Significant", "NS"))

res_wt_iso_df <- res_wt_iso_df[order(res_wt_iso_df$sig, decreasing = TRUE), ]

res_wt_iso_df$repel_label <- ifelse(
  res_wt_iso_df$label %in% complement_present &
  !is.na(res_wt_iso_df$padj) &
  res_wt_iso_df$padj < 0.05 &
  res_wt_iso_df$log10FC > 0,
  res_wt_iso_df$label,
  ""
)

p_vol_wt_iso <- ggplot(res_wt_iso_df,
    aes(x = log10FC, y = neg_log10_padj, color = sig)) +
  geom_point(size = 1.2, alpha = 0.7) +
  geom_hline(yintercept = -log10(0.05), linetype = "dashed", color = "grey50", linewidth = 0.4) +
  geom_vline(xintercept = 0, linetype = "dashed", color = "grey50", linewidth = 0.4) +
  geom_text_repel(
