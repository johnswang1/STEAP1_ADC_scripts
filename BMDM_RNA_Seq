# Faceted dot plot of complement gene VST expression across all 4 conditions
vsd_mat_df <- as.data.frame(assay(vsd_mouse))
vsd_mat_df$Geneid <- rownames(vsd_mat_df)
vsd_mat_df$Geneid_clean <- sub("^mouse_", "", vsd_mat_df$Geneid)
vsd_mat_df$Geneid_clean <- sub("\\..*$", "", vsd_mat_df$Geneid_clean)

vsd_mat_df$SYMBOL <- mapIds(
  org.Mm.eg.db,
  keys      = vsd_mat_df$Geneid_clean,
  column    = "SYMBOL",
  keytype   = "ENSEMBL",
  multiVals = "first"
)

comp_vsd <- vsd_mat_df %>%
  filter(SYMBOL %in% complement_present) %>%
  mutate(mean_all = rowMeans(across(all_of(paste0("A", 1:12))), na.rm = TRUE)) %>%
  arrange(SYMBOL, desc(mean_all)) %>%
  filter(!duplicated(SYMBOL))

sample_condition <- setNames(as.character(meta_mouse$Condition), meta_mouse$Sample)

comp_long <- comp_vsd %>%
  select(SYMBOL, all_of(paste0("A", 1:12))) %>%
  pivot_longer(-SYMBOL, names_to = "Sample", values_to = "VST") %>%
  mutate(
    Condition = factor(sample_condition[Sample],
                       levels = c("isotype", "WT", "WT_Exatecan", "WT_MMAE"))
  )

comp_summary <- comp_long %>%
  group_by(SYMBOL, Condition) %>%
  summarise(
    mean_VST = mean(VST, na.rm = TRUE),
    sem_VST  = sd(VST, na.rm = TRUE) / sqrt(n()),
    .groups  = "drop"
  )

p_comp_dot <- ggplot(comp_summary, aes(x = Condition, y = mean_VST, color = Condition)) +
  geom_point(size = 2.5) +
  geom_errorbar(aes(ymin = mean_VST - sem_VST, ymax = mean_VST + sem_VST), width = 0.3) +
  facet_wrap(~ SYMBOL, scales = "free_y", ncol = 5) +
  scale_color_manual(values = c(
    isotype     = "grey50",
    WT          = "#4DAF4A",
    WT_Exatecan = "#3B7DC6",
    WT_MMAE     = "#C65D3B"
  )) +
  labs(
    x = NULL, y = "VST expression",
    title = "Complement gene expression across conditions"
  ) +
  theme_bw(base_size = 10) +
  theme(
    axis.text.x     = element_text(angle = 35, hjust = 1, size = 7),
    strip.text      = element_text(face = "bold", size = 8),
    legend.position = "none"
  )

p_comp_dot

tiff(
  file.path(results_dir, "Supp_Complement_dotplot_all_conditions.tiff"),
  width = 14, height = 10, units = "in", res = 600, compression = "lzw"
)
print(p_comp_dot)
