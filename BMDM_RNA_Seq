```{r helper-functions}
# Helper: build a condition-averaged, z-scored heatmap matrix from expr_df

make_condition_avg_matrix <- function(df, gene_list, sample_cols) {
  sub_df <- df[df$GeneName %in% gene_list, , drop = FALSE]
  sub_df <- sub_df[!is.na(sub_df$GeneName) & sub_df$GeneName != "", , drop = FALSE]

  sub_df$mean_expr_tmp <- rowMeans(sub_df[, sample_cols, drop = FALSE], na.rm = TRUE)
  sub_df <- sub_df[order(sub_df$GeneName, -sub_df$mean_expr_tmp), , drop = FALSE]
  sub_df <- sub_df[!duplicated(sub_df$GeneName), , drop = FALSE]

  rownames(sub_df) <- sub_df$GeneName

  expr_mat <- sub_df[, sample_cols, drop = FALSE]
  expr_mat[] <- lapply(expr_mat, as.numeric)
  expr_mat <- as.data.frame(expr_mat)

  avg_mat <- data.frame(
    isotype = rowMeans(expr_mat[, c("A1","A2","A3"), drop = FALSE], na.rm = TRUE),
    WT = rowMeans(expr_mat[, c("A4","A5","A6"), drop = FALSE], na.rm = TRUE),
    WT_Exatecan = rowMeans(expr_mat[, c("A7","A8","A9"), drop = FALSE], na.rm = TRUE),
    WT_MMAE = rowMeans(expr_mat[, c("A10","A11","A12"), drop = FALSE], na.rm = TRUE)
  )

  rownames(avg_mat) <- rownames(expr_mat)
  avg_mat
}

make_condition_heatmap_matrix <- function(df, gene_list, sample_cols) {
  avg_mat <- make_condition_avg_matrix(df, gene_list, sample_cols)
  avg_mat <- avg_mat[apply(avg_mat, 1, sd, na.rm = TRUE) > 0, , drop = FALSE]
  scaled_mat <- t(scale(t(avg_mat)))
  scaled_mat <- scaled_mat[complete.cases(scaled_mat), , drop = FALSE]
  scaled_mat
}
```

